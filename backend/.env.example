# Movie Frame Browser - 环境变量
# 复制为 .env 后按需修改。未设置的项使用 config 中的默认值。

# ============================================
# 服务
# ============================================

NODE_ENV=production
PORT=60008

# 前端部署子路径，与 Vite base 一致；根路径部署设为 PUBLIC_PATH=
PUBLIC_PATH=/movie

# ============================================
# 目录（绝对路径推荐）
# ============================================

# JSON 元数据：movies.json、tasks.json
DATA_PATH=/home/chenkh/workspace/movie-frame-browser/data

# 静态输出：covers、frames、clips；其下 temp 为 FFmpeg 临时文件
STORAGE_PATH=/home/chenkh/workspace/movie-frame-browser/static

# 可选，默认 STORAGE_PATH/temp
# TEMP_PATH=/opt/movie-frame-browser/static/temp

# ============================================
# 本地电影（「选择电影」扫描目录）
# ============================================

LOCAL_MOVIES_DIR=/mnt/f/downloaded
LOCAL_MOVIES_SCAN_ON_START=true

# ============================================
# FFmpeg
# ============================================

# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe

FFMPEG_THREADS=1
FFMPEG_TIMEOUT=300000
# FFMPEG_PRIORITY=low

CLIP_FFMPEG_TIMEOUT_SEC=20

# ============================================
# 抽帧与预览片段
# ============================================

DEFAULT_FRAME_WIDTH=1280
DEFAULT_FRAME_QUALITY=75
DEFAULT_FRAME_INTERVAL=60

CLIP_SEEK_BACK=1
CLIP_SEEK_FORWARD=5
CLIP_CONTINUE_OFFSET=1

# ============================================
# 任务队列
# ============================================

MAX_CONCURRENT_FFMPEG=2
# MAX_CONCURRENT_FFMPEG=auto
CPU_LOAD_THRESHOLD=0.8

# ============================================
# 缓存（启动时按阈值自动清理）
# ============================================

# 字节数，默认 10737418240（10GB）
MAX_CACHE_SIZE=10737418240
CACHE_CLEANUP_THRESHOLD=0.9
CACHE_CLEANUP_TARGET=0.7

# ============================================
# CORS（生产环境限制来源，逗号分隔）
# ============================================

# ALLOWED_ORIGINS=https://your-domain.com
